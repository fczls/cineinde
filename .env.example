# Supabase (required for scraper + migration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For apply_schema.py: direct connection (from Dashboard → Settings → Database → Connection string)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# Optional: for frontend — à copier dans index.html (CONFIG) pour le site en ligne
# SUPABASE_ANON_KEY=your-anon-key

# Scraper enrichment (optional)
OMDB_API_KEY=
TMDB_API_KEY=
